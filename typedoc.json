{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "packages/preflight-core/src/index.ts",
    "packages/clearance-core/src/index.ts",
    "packages/eip7702/src/index.ts",
    "packages/mcp/src/server.ts",
    "packages/adapter-langchain/src/index.ts",
    "packages/adapter-openai-agents/src/index.ts",
    "packages/adapter-tokamak/src/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "out": "docs/api",
  "name": "preflight",
  "readme": "README.md",
  "includeVersion": true,
  "navigationLinks": {
    "GitHub": "https://github.com/preflight-sh/preflight",
    "npm": "https://www.npmjs.com/package/@preflight/core"
