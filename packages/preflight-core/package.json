{
  "name": "@preflight/core",
  "version": "0.2.0",
  "description": "AI agent behavioral testing framework for EVM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/preflight-sh/preflight"
  },
  "keywords": [
    "ai-agent",
    "testing",
    "evm",
    "blockchain",
    "anvil",
    "mock-llm",
    "preflight"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.config.live.ts",
    "dev": "vitest"
  },
  "dependencies": {
    "@clearance/core": "workspace:^",
    "@viem/anvil": "^0.0.9",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
