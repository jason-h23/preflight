{
  "name": "preflight-monorepo",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "docs": "typedoc",
    "docs:serve": "typedoc && npx serve docs/api",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "pnpm": {
    "overrides": {
      "signal-exit": "^4.1.0"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "tsup": "^8.0.0",
    "turbo": "^2.0.0",
    "typedoc": "^0.27.9",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
